# Firebase Web config (public — safe to expose to the browser).
# Firebase Console → Project settings → General → Your apps → Web app → SDK setup and configuration.
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=

# Firebase Admin service account (private — server-only, never expose to the browser).
# Firebase Console → Project settings → Service accounts → Generate new private key.
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# This deployment's own public URL, no trailing slash (public — safe to expose).
# Used as the return URL for Firebase email-verification and password-reset links.
# Local dev: falls back to the browser's origin automatically if left unset.
# Production: set to the real Vercel/custom domain, e.g. https://listy.example.com
NEXT_PUBLIC_APP_URL=
